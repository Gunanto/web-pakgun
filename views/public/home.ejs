<%- include('../partials/header') %>

<%
  const heroSlides = heroMedia && heroMedia.length ? heroMedia : [];
  const avatarSrc = landingAvatarUrl || (heroSlides[0] ? heroSlides[0].src : "");
  const socialItems = [
    {
      key: "github",
      label: "GitHub",
      href: socialLinks.github,
      filled: true,
      icon: '<path d="M12 2.5a9.5 9.5 0 0 0-3 18.5c.47.09.64-.2.64-.46v-1.63c-2.61.57-3.16-1.1-3.16-1.1-.43-1.08-1.04-1.36-1.04-1.36-.84-.58.06-.57.06-.57.94.07 1.43.95 1.43.95.82 1.43 2.17 1.01 2.7.77.08-.61.33-1.01.59-1.24-2.09-.24-4.28-1.04-4.28-4.62 0-1.02.36-1.85.95-2.5-.09-.23-.41-1.19.1-2.47 0 0 .78-.25 2.56.95A8.7 8.7 0 0 1 12 6.84c.77 0 1.55.1 2.28.31 1.77-1.2 2.55-.95 2.55-.95.52 1.28.2 2.24.1 2.47.59.65.95 1.49.95 2.5 0 3.59-2.19 4.38-4.29 4.61.34.29.64.84.64 1.69v2.51c0 .26.17.56.65.46A9.5 9.5 0 0 0 12 2.5Z"></path>'
    },
    {
      key: "linkedin",
      label: "LinkedIn",
      href: socialLinks.linkedin,
      filled: true,
      icon: '<path d="M6.5 8.5A1.5 1.5 0 1 1 6.5 5.5a1.5 1.5 0 0 1 0 3Zm-1.25 2.25h2.5v8h-2.5Zm5 0h2.4v1.1h.03c.33-.63 1.15-1.3 2.37-1.3 2.53 0 3 1.66 3 3.82v4.38h-2.5v-3.89c0-.93-.02-2.12-1.29-2.12-1.3 0-1.5 1.02-1.5 2.06v3.95h-2.5Z"></path>'
    },
    {
      key: "facebook",
      label: "Facebook",
      href: socialLinks.facebook,
      filled: true,
      icon: '<path d="M13.5 21v-7h2.3l.35-2.7H13.5V9.58c0-.78.22-1.31 1.34-1.31h1.43V5.86c-.25-.03-1.09-.11-2.06-.11-2.03 0-3.42 1.24-3.42 3.52v1.97H8.5V14h2.34v7Z"></path>'
    },
    {
      key: "twitter",
      label: "Twitter",
      href: socialLinks.twitter,
      filled: true,
      icon: '<path d="m18.9 5-5 5.72L18.5 19h-2.6l-3.42-5.18L7.96 19H5.4l5.3-6.07L6.25 5h2.6l3.17 4.83L16.27 5Z"></path>'
    },
    {
      key: "instagram",
      label: "Instagram",
      href: socialLinks.instagram,
      icon: '<rect x="5" y="5" width="14" height="14" rx="4"></rect><circle cx="12" cy="12" r="3.25"></circle><circle cx="16.4" cy="7.6" r="1"></circle>'
    },
    {
      key: "youtube",
      label: "YouTube",
      href: socialLinks.youtube,
      filled: true,
      icon: '<path d="M19.6 8.3a2.5 2.5 0 0 0-1.76-1.77C16.3 6.1 12 6.1 12 6.1s-4.3 0-5.84.43A2.5 2.5 0 0 0 4.4 8.3 26 26 0 0 0 4 12a26 26 0 0 0 .4 3.7 2.5 2.5 0 0 0 1.76 1.77c1.54.43 5.84.43 5.84.43s4.3 0 5.84-.43a2.5 2.5 0 0 0 1.76-1.77A26 26 0 0 0 20 12a26 26 0 0 0-.4-3.7Z"></path><path d="m10.25 14.85 4.5-2.85-4.5-2.85Z"></path>'
    },
    {
      key: "telegram",
      label: "Telegram",
      href: socialLinks.telegram,
      icon: '<path d="m20 4-2.8 15.1c-.2 1.07-.82 1.34-1.66.84l-4.6-3.39-2.22 2.14c-.24.24-.45.45-.93.45l.33-4.72L16.7 6.7c.37-.33-.08-.52-.58-.19L5.64 13.11l-4.52-1.41c-.98-.31-1-.98.2-1.45L18.9 3.5c.82-.3 1.53.19 1.1 1.5Z"></path>'
    },
    {
      key: "email",
      label: "Email",
      href: socialLinks.email ? `mailto:${socialLinks.email}` : "",
      icon: '<rect x="4" y="6" width="16" height="12" rx="2"></rect><path d="m5 8 7 5 7-5"></path>'
    }
  ].filter((item) => item.href);
%>

<section class="landing-hero" id="top" data-slider>
  <div class="landing-slider" aria-hidden="true">
    <% if (heroSlides.length) { %>
      <% heroSlides.forEach((slide, index) => { %>
        <div class="landing-slide <%= index === 0 ? 'is-active' : '' %>" data-slide>
          <img
            class="landing-slide-media"
            src="<%= slide.src %>"
            alt=""
            loading="<%= index === 0 ? 'eager' : 'lazy' %>"
            decoding="async"
          />
        </div>
      <% }) %>
    <% } else { %>
      <div class="landing-slide landing-slide-fallback is-active" data-slide></div>
    <% } %>
  </div>

  <div class="landing-overlay"></div>

  <% if (heroSlides.length > 1) { %>
    <button class="landing-arrow landing-arrow-prev" type="button" aria-label="Slide sebelumnya" data-slider-prev>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7"></path></svg>
    </button>
    <button class="landing-arrow landing-arrow-next" type="button" aria-label="Slide berikutnya" data-slider-next>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7"></path></svg>
    </button>
  <% } %>

  <div class="landing-center">
    <% if (avatarSrc) { %>
      <div class="landing-avatar">
        <img src="<%= avatarSrc %>" alt="<%= siteTitle %>" />
      </div>
    <% } %>

    <div class="landing-card">
      <h1><%= homepageTitle %></h1>
      <p><%= homepageSubtitle %></p>
      <% if (siteTagline) { %>
        <small><%= siteTagline %></small>
      <% } %>
    </div>

    <% if (socialItems.length) { %>
      <div class="landing-social" aria-label="Tautan sosial">
        <% socialItems.forEach((item) => { %>
          <a href="<%= item.href %>" class="social-pill <%= item.filled ? 'is-fill' : '' %>" target="<%= item.key === 'email' ? '_self' : '_blank' %>" rel="<%= item.key === 'email' ? '' : 'noopener noreferrer' %>" aria-label="<%= item.label %>">
            <svg viewBox="0 0 24 24" aria-hidden="true"><%- item.icon %></svg>
          </a>
        <% }) %>
      </div>
    <% } %>

    <% if (heroSlides.length > 1) { %>
      <div class="landing-dots" aria-label="Navigasi slide">
        <% heroSlides.forEach((slide, index) => { %>
          <button class="landing-dot <%= index === 0 ? 'is-active' : '' %>" type="button" aria-label="Pilih slide <%= index + 1 %>" data-slider-dot="<%= index %>"></button>
        <% }) %>
      </div>
    <% } %>

    <a href="#pages" class="landing-scroll" aria-label="Lihat bagian berikutnya">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
    </a>
  </div>
</section>

<section id="pages" class="landing-content">
  <div class="section-heading">
    <div>
      <p class="section-eyebrow">Halaman Publik</p>
      <h2>Konten terbaru</h2>
    </div>
  </div>

  <% if (!pages.length) { %>
    <div class="card empty-state">
      <p>Belum ada halaman publik yang diterbitkan.</p>
      <small>Upload beberapa gambar di Media Library untuk menghidupkan landing page ini.</small>
    </div>
  <% } else { %>
    <div class="grid">
      <% pages.forEach((item) => { %>
        <article class="card page-card">
          <h3><a href="/p/<%= item.slug %>"><%= item.title %></a></h3>
          <p>Slug: <code><%= item.slug %></code></p>
          <small>Oleh <%= item.author_name %> • update <%= new Date(item.updated_at).toLocaleString('id-ID') %></small>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<script>
  (function () {
    const root = document.querySelector("[data-slider]");
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-slider-dot]"));
    const prev = root.querySelector("[data-slider-prev]");
    const next = root.querySelector("[data-slider-next]");
    if (slides.length <= 1) return;

    let current = 0;
    let timer = null;
    let pointerId = null;
    let startX = 0;
    let startY = 0;
    let isPointerDown = false;
    let isDragging = false;

    const render = (index) => {
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle("is-active", slideIndex === current);
      });
      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("is-active", dotIndex === current);
      });
    };

    const schedule = () => {
      window.clearInterval(timer);
      timer = window.setInterval(() => render(current + 1), 6000);
    };

    const resetPointer = () => {
      pointerId = null;
      isPointerDown = false;
      isDragging = false;
      root.classList.remove("is-dragging");
    };

    const handleSwipe = (deltaX) => {
      const threshold = 50;
      if (Math.abs(deltaX) < threshold) return;
      render(deltaX < 0 ? current + 1 : current - 1);
      schedule();
    };

    prev && prev.addEventListener("click", () => {
      render(current - 1);
      schedule();
    });

    next && next.addEventListener("click", () => {
      render(current + 1);
      schedule();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        render(index);
        schedule();
      });
    });

    root.addEventListener("pointerdown", (event) => {
      if (event.pointerType === "mouse" && event.button !== 0) return;
      if (event.target.closest("a, button, input, textarea, label")) return;

      pointerId = event.pointerId;
      startX = event.clientX;
      startY = event.clientY;
      isPointerDown = true;
      isDragging = false;
      root.classList.add("is-dragging");
      window.clearInterval(timer);
    });

    root.addEventListener("pointermove", (event) => {
      if (!isPointerDown || event.pointerId !== pointerId) return;

      const deltaX = event.clientX - startX;
      const deltaY = event.clientY - startY;

      if (!isDragging && Math.abs(deltaX) > 12 && Math.abs(deltaX) > Math.abs(deltaY)) {
        isDragging = true;
      }
    });

    const finishSwipe = (event) => {
      if (!isPointerDown || event.pointerId !== pointerId) return;
      const deltaX = event.clientX - startX;
      const deltaY = event.clientY - startY;
      const horizontalSwipe = Math.abs(deltaX) > Math.abs(deltaY);

      if (horizontalSwipe) {
        handleSwipe(deltaX);
      } else {
        schedule();
      }

      resetPointer();
    };

    root.addEventListener("pointerup", finishSwipe);
    root.addEventListener("pointercancel", () => {
      schedule();
      resetPointer();
    });
    root.addEventListener("pointerleave", (event) => {
      if (event.pointerType !== "mouse" || !isPointerDown) return;
      finishSwipe(event);
    });

    render(0);
    schedule();
  })();
</script>

<%- include('../partials/footer') %>
