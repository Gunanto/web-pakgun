<%- include('../../partials/header') %>

<section class="form-card">
  <h1>Edit Halaman</h1>

  <form action="/admin/pages/<%= page.id %>/update" method="POST" class="form-stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>
      Judul
      <input type="text" name="title" value="<%= page.title %>" required />
    </label>

    <label>
      Slug
      <input type="text" name="slug" value="<%= page.slug %>" required />
    </label>

    <div class="form-field">
      <span class="field-label">Konten</span>
      <div class="editor-shell">
        <div id="editor-toolbar">
          <span class="ql-formats">
            <select class="ql-size" title="Ukuran font">
              <option selected></option>
              <option value="small"></option>
              <option value="large"></option>
              <option value="huge"></option>
            </select>
            <select class="ql-header" title="Heading">
              <option selected></option>
              <option value="1"></option>
              <option value="2"></option>
              <option value="3"></option>
            </select>
            <button class="ql-bold"></button>
            <button class="ql-italic"></button>
            <button class="ql-underline"></button>
            <button class="ql-strike"></button>
          </span>
          <span class="ql-formats">
            <button class="ql-list" value="ordered"></button>
            <button class="ql-list" value="bullet"></button>
            <button class="ql-blockquote"></button>
            <button class="ql-code-block"></button>
          </span>
          <span class="ql-formats">
            <button class="ql-link"></button>
            <button class="ql-image"></button>
            <select class="ql-color" title="Warna teks"></select>
            <button class="ql-formula"></button>
            <button class="ql-clean"></button>
          </span>
        </div>
        <div id="editor" class="editor"></div>
        <textarea name="content" id="content" hidden required></textarea>
      </div>
    </div>

    <label>
      Status
      <select name="status">
        <option value="draft" <%= page.status === 'draft' ? 'selected' : '' %>>Draft</option>
        <option value="published" <%= page.status === 'published' ? 'selected' : '' %>>Published</option>
      </select>
    </label>

    <div class="form-actions">
      <button class="button" type="submit">Update</button>
      <a href="/admin/pages" class="button secondary">Batal</a>
    </div>
  </form>
</section>

<%- include('../../partials/footer') %>

<link href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
  const initialContent = <%- JSON.stringify(page.content || '') %>;
  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: { toolbar: '#editor-toolbar' }
  });
  quill.root.innerHTML = initialContent;

  const contentInput = document.getElementById('content');
  const form = document.querySelector('form');
  const syncContent = () => {
    contentInput.value = quill.root.innerHTML.trim();
  };
  syncContent();
  quill.on('text-change', syncContent);
  form.addEventListener('submit', syncContent);
</script>
