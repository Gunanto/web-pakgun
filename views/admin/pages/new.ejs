<%- include('../../partials/header') %>

<section class="form-card">
  <h1>Buat Halaman Baru</h1>

  <form action="/admin/pages" method="POST" class="form-stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>
      Judul
      <input type="text" name="title" required />
    </label>

    <label>
      Slug (opsional)
      <input type="text" name="slug" placeholder="contoh-profil-sekolah" />
    </label>

    <label>
      Konten
      <div class="editor-shell">
        <div id="editor-toolbar">
          <span class="ql-formats">
            <select class="ql-header"></select>
            <button class="ql-bold"></button>
            <button class="ql-italic"></button>
            <button class="ql-underline"></button>
            <button class="ql-strike"></button>
          </span>
          <span class="ql-formats">
            <button class="ql-list" value="ordered"></button>
            <button class="ql-list" value="bullet"></button>
            <button class="ql-blockquote"></button>
            <button class="ql-code-block"></button>
          </span>
          <span class="ql-formats">
            <button class="ql-link"></button>
            <button class="ql-image"></button>
            <button class="ql-clean"></button>
          </span>
        </div>
        <div id="editor" class="editor"></div>
        <textarea name="content" id="content" hidden required></textarea>
      </div>
    </label>

    <label>
      Status
      <select name="status">
        <option value="draft">Draft</option>
        <option value="published">Published</option>
      </select>
    </label>

    <div class="form-actions">
      <button class="button" type="submit">Simpan</button>
      <a href="/admin/pages" class="button secondary">Batal</a>
    </div>
  </form>
</section>

<%- include('../../partials/footer') %>

<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Tulis konten halaman...',
    modules: { toolbar: '#editor-toolbar' }
  });

  const contentInput = document.getElementById('content');
  const form = document.querySelector('form');
  const syncContent = () => {
    contentInput.value = quill.root.innerHTML.trim();
  };
  quill.on('text-change', syncContent);
  form.addEventListener('submit', syncContent);
</script>
